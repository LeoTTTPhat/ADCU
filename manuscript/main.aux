\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces Pipeline-deletion composition (Appendix~A). Per-component deletion errors compose additively---$\varepsilon _\theta $ on parameters, $\varepsilon _K$ on knowledge amplified by the generation Lipschitz factor $L$---plus a non-additive derivative-coupling term $\gamma _z$ that is zero \emph  {iff} every derivative of the deleted record has also been removed; otherwise orphan derivatives dominate.}}{5}{figure.1}\protected@file@percent }
\newlabel{fig:composition}{{1}{5}{Pipeline-deletion composition (Appendix~A). Per-component deletion errors compose additively---$\varepsilon _\theta $ on parameters, $\varepsilon _K$ on knowledge amplified by the generation Lipschitz factor $L$---plus a non-additive derivative-coupling term $\gamma _z$ that is zero \emph {iff} every derivative of the deleted record has also been removed; otherwise orphan derivatives dominate}{figure.1}{}}
